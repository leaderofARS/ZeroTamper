# ==============================================================================
# WitnessChain Root Environment Configuration Reference
# ==============================================================================
# This is a master reference file. You should copy the relevant sections 
# into their respective .env files in each sub-project:
#   1. apps/backend/.env
#   2. apps/dashboard/.env
#   3. ml/deepfake-detector/.env
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. BACKEND API (apps/backend/.env)
# ------------------------------------------------------------------------------
PORT=4000
NODE_ENV=development
CORS_ORIGIN=*

# Solana Network
SOLANA_RPC_URL=https://api.devnet.solana.com
# Replace with the deployed Anchor Program ID
PROGRAM_ID=REPLACE_WITH_DEPLOYED_PROGRAM_ID
# Service wallet private key (JSON array) - DO NOT SHARE YOUR REAL MAINNET KEY
SOLANA_PRIVATE_KEY=[0,0,0,0,0,0]

# Supabase (Database & Auth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_key_here

# IPFS Pinning (Pinata)
PINATA_JWT=your_pinata_jwt_here

# Services Integration
ML_SERVICE_URL=http://localhost:5001
LEGAL_API_SECRET=your_legal_secret_here


# ------------------------------------------------------------------------------
# 2. DASHBOARD FRONTEND (apps/dashboard/.env)
# ------------------------------------------------------------------------------
# Point to your local or deployed backend API
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# Mapbox token for the interactive heatmap
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here


# ------------------------------------------------------------------------------
# 3. ML / DEEPFAKE DETECTOR (ml/deepfake-detector/.env)
# ------------------------------------------------------------------------------
ML_PORT=5001
