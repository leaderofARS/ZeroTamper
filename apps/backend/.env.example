# ── Backend Configuration ──
PORT=4000
NODE_ENV=development
CORS_ORIGIN=*

# ── Solana Configuration ──
SOLANA_RPC_URL=https://api.devnet.solana.com
# The program ID deployed to devnet
PROGRAM_ID=REPLACE_WITH_DEPLOYED_PROGRAM_ID
# Service wallet private key (JSON byte array) used to sign transactions automatically
SOLANA_PRIVATE_KEY=[0,0,0,...]

# ── Supabase Configuration ──
SUPABASE_URL=https://your-project.supabase.co
# Service role key for admin access
SUPABASE_SERVICE_KEY=your_service_key_here

# ── IPFS / Pinata ──
PINATA_JWT=your_pinata_jwt_here

# ── Services ──
ML_SERVICE_URL=http://localhost:5001
LEGAL_API_SECRET=your_legal_secret_here
