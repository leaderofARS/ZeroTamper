{
  "name": "witnesschain",
  "version": "1.0.0",
  "description": "Decentralized Bystander Evidence Network on Solana",
  "private": true,
  "workspaces": [
    "apps/backend",
    "apps/dashboard"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace=apps/backend",
    "dev:dashboard": "npm run dev --workspace=apps/dashboard",
    "dev:mobile": "npm run start --prefix apps/mobile",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:dashboard\"",
    "build": "npm run build --workspace=apps/dashboard",
    "test": "anchor test"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "@openai/codex": "^0.129.0",
    "skills": "^1.5.5"
  },
  "overrides": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  }
}
